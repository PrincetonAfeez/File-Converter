# DEBUG defaults to False. When False, DJANGO_SECRET_KEY MUST be a strong, unique value
# (the app refuses to start otherwise).
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False
FILECONVERTER_STORAGE_ROOT=media
# Scratch dir for in-flight conversions; kept outside the served media tree.
FILECONVERTER_WORK_ROOT=work
FILECONVERTER_MAX_UPLOAD_MB=50
# Reject uploads whose sniffed content contradicts their extension (needs libmagic).
FILECONVERTER_ENFORCE_MIME_MATCH=True
# Fail uploads closed when the MIME scanner (libmagic) is unavailable instead of skipping.
FILECONVERTER_REQUIRE_MIME_SCANNER=False
# Max claim attempts before a transient failure becomes terminal.
FILECONVERTER_MAX_ATTEMPTS=3
# Retention (days) for QuotaDecision audit rows; purged by a periodic beat task.
FILECONVERTER_QUOTA_DECISION_TTL_DAYS=30
# Neutralize spreadsheet formula cells on CSV/XLSX output (CSV injection defense).
FILECONVERTER_SANITIZE_SPREADSHEET_FORMULAS=True
# Max rows for tabular conversions (bounds memory; under the .xlsx row limit).
FILECONVERTER_MAX_TABLE_ROWS=1000000
# Login throttling (needs a shared cache like Redis for accurate multi-process enforcement).
FILECONVERTER_LOGIN_MAX_ATTEMPTS=10
FILECONVERTER_LOGIN_BLOCK_SECONDS=300
FILECONVERTER_LOGIN_IP_MAX_ATTEMPTS=50
# Trusted reverse proxies in front of the app (0 = none). When >0 the real client IP is
# taken from X-Forwarded-For; set this behind nginx/ALB so throttling isn't proxy-wide.
FILECONVERTER_TRUSTED_PROXY_COUNT=0
# Request-rate throttle on the upload/convert endpoint (per user per window).
FILECONVERTER_UPLOAD_RATE_MAX=20
FILECONVERTER_UPLOAD_RATE_WINDOW_SECONDS=60
# Session lifetime (seconds) and DB persistent-connection lifetime (seconds).
DJANGO_SESSION_COOKIE_AGE=28800
DJANGO_DB_CONN_MAX_AGE=60
# Error tracking: required when DJANGO_DEBUG=False (check --deploy + /ops/ready/).
# Opt out only for ephemeral stacks: FILECONVERTER_REQUIRE_SENTRY=False
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
FILECONVERTER_REQUIRE_SENTRY=
# Synthetic uptime target (GitHub Actions secret STAGING_BASE_URL for scheduled probes).
# STAGING_BASE_URL=https://staging.example.com
# Log DB queries slower than this many ms (0 disables). Default 500 when DJANGO_DEBUG=False.
FILECONVERTER_SLOW_QUERY_MS=0
# Emit logs as JSON (for Loki/ELK/Datadog) instead of text.
FILECONVERTER_JSON_LOGS=False
# Warn when a broker queue exceeds this many pending messages.
FILECONVERTER_QUEUE_BACKLOG_ALERT=100
# Bearer token to scrape /ops/metrics/ (empty = staff-session only; anonymous always denied).
FILECONVERTER_METRICS_TOKEN=
# Retention (hours) for stored INPUT file bytes after a job reaches a terminal state.
FILECONVERTER_INPUT_TTL_HOURS=24
# Retention (hours) before an unreferenced FileBlob (orphan) is garbage-collected.
FILECONVERTER_BLOB_GC_TTL_HOURS=48
# Outbox webhook delivery. Leave URL empty to record events without delivering them.
FILECONVERTER_WEBHOOK_URL=
FILECONVERTER_WEBHOOK_TIMEOUT_SECONDS=5
# Shared secret for HMAC-SHA256 webhook signatures (X-Signature: sha256=...). Empty = unsigned.
FILECONVERTER_WEBHOOK_SECRET=
FILECONVERTER_OUTBOX_MAX_ATTEMPTS=8
# Shared Redis cache (required in production for throttles, beat mutex, progress).
FILECONVERTER_USE_REDIS_CACHE=False

# --- Production TLS hardening (defaults active when DJANGO_DEBUG=False) ---
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
